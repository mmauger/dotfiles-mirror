Host git.sv.gnu.org  git.savannah.gnu.org
   # ForwardX11 no
   # ForwardX11Trusted no

Host *.pagekite.me
  CheckHostIP no
  ProxyCommand /usr/bin/corkscrew %h 443 %h %p

# GitLab.com
Host gitlab.com
   Preferredauthentications publickey
   IdentityFile ~/.ssh/id_ed25519_gitlab
   # ForwardX11 no
   # ForwardX11Trusted no

# GitHub.com
Host github.com
   Preferredauthentications publickey
   IdentityFile ~/.ssh/id_ed25519_github
   # ForwardX11 no
   # ForwardX11Trusted no

# Host *
#   ControlMaster auto
#   ControlPath /tmp/%r@%h:%p
ControlMaster auto
ControlPath /tmp/%r@%h:%p

Compression yes
# ForwardX11 yes
# ForwardX11Trusted yes
ServerAliveInterval 5
EscapeChar none
