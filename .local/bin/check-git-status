#! /usr/bin/env bash
set -eu -o pipefail

PROG="$( basename "$0" )"
PDIR="$( cd "$( dirname "$0" )" && pwd )"

if (( $# > 0 )) && [[ $1 =~ \'[-]+[Hh](elp)?\' ]]; then
    cat >&2 <<-ENDHELP
	usage: ${PROG} ...
	ENDHELP
    exit 2
fi

ON=$( tput smul || true )
OFF=$( tput rmul || true )

#
function git-status-summary { # dir [flags]
    local repo=$1; shift
    git -C "${repo}" status --short "$@"
}

function projects-dir {
    find ~ \
         -maxdepth 1 \
         -type d \
         \( -name 'Projects' \
         -o -name 'Project' \
         -o -name 'Development' \
         -o -name 'Develop' \
         \) -print \
        | head -1
}

cd "$( projects-dir )"

find . -type d -name .git -print | while read -r p; do
    proj="$( dirname "${p#./}" )"
    n_changes=$( git-status-summary "${proj}" --untracked-files=no | wc -l )
    if (( n_changes > 0 )); then
        echo '* ' "${ON}${proj}${OFF}"
        git-status-summary "${proj}" --ignored=no
        echo
    fi
done

#
